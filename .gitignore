# Jekyll local builds (Pages builds remotely)
docs/_site/
docs/.jekyll-cache/
docs/.jekyll-metadata
docs/Gemfile.lock
docs/vendor/

# TFactory runtime state (user home dir)
# (Listed for documentation; not actually under repo root)
# ~/.tfactory/

# Docker scratch
.docker-scratch/

# /demo working directories (per-run panes/casts) — only the clean
# docs/static/demos/ media is committed for the Pages showcase.
docs/static/recordings/
.claude/worktrees/
.claude/scheduled_tasks.lock

# Vite build output for the portal — hashed bundle filenames change every
# build, producing large churn + checkout reverts. The frontend is built
# (`apps/frontend-web` → outDir ../web-server/static) and served in prod; the
# hashed asset bundle is regenerated, never hand-edited, so it is not tracked.
apps/web-server/static/assets/
apps/web-server/static/index.html
