# =============================================================================
# TFactory — root .env.example
# =============================================================================
# Copy to `.env` next to docker-compose.yml and override values as needed.
#
# This file is for the LOCAL DEV docker-compose deployment AND as a
# reference index of TFactory env vars. Production deployments use
# the Helm chart — see guides/deployment/runbook.md.
#
# Per-app envs live alongside their app:
#   - Web-server portal:  apps/web-server/.env.example
#   - Backend agents:     (no per-app .env.example yet; vars listed below)
# =============================================================================


# ─── docker-compose host port mapping ──────────────────────────────────
# Host port the web server is published to. Default 3102 matches APP_PORT.
# HOST_PORT=3102


# ─── docker-compose persistent data ────────────────────────────────────
# Bind-mounted at /home/nonroot/.tfactory inside the container. Holds the
# auto-generated API token, project metadata, audit log SQLite (until P1
# Postgres migration lands).
# TFACTORY_DATA_DIR=./data


# ─── Container runtime overrides (forwarded into the container) ────────
# Auto-generated on first run if unset.
# APP_API_TOKEN=

# Set via the UI OAuth flow instead (preferred).
# CLAUDE_CODE_OAUTH_TOKEN=

# Extra CORS origins for the web-server (comma-separated or JSON list).
# APP_CORS_ORIGINS=https://my-host.example.com:3102,http://my-host.example.com:3100


# ─── Agent LLM provider keys (used by Planner / Gen-Functional /
#     Evaluator / Triager when they call out via the providers/factory) ─
# At least ONE of these must be set for the pipeline to run.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# GOOGLE_API_KEY=
# VOYAGE_API_KEY=


# ─── TFactory workspace + pipeline ─────────────────────────────────────
# Workspace root that the portal endpoints + the agents read/write from.
# Default ~/.tfactory.
# TFACTORY_WORKSPACE_ROOT=~/.tfactory

# Auto-fire chain envs — each defaults to "1" (auto-advance ON). Test
# fixtures set to "0"; operators may pin some OFF to inspect each stage.
# TFACTORY_AUTO_PLAN=1       # Planner auto-fires from task_create_and_run
# TFACTORY_AUTO_GENERATE=1   # Gen-Functional auto-fires from Planner
# TFACTORY_AUTO_EVALUATE=1   # Evaluator auto-fires from Gen-Functional
# TFACTORY_AUTO_TRIAGE=1     # Triager auto-fires from Evaluator


# ─── Triager side-effect modes (default DRY-RUN — opt in to real-run) ──
# Per CLAUDE.md: "NO automatic pushes to GitHub" — keep these off unless
# the operator has confirmed git_writer/pr_comment are safe.
# TFACTORY_TRIAGER_GIT_WRITE=0     # commit accepted tests to feature branch
# TFACTORY_TRIAGER_PR_COMMENT=0    # post triage report via gh pr comment


# ─── AIFactory project location (used by the snapshotter + e2e smoke) ──
# Local path to the AIFactory checkout TFactory operates on.
# TFACTORY_AIFACTORY_ROOT=/home/user/Source/GitHub/MyApp
# Feature branch carrying the change to test:
# TFACTORY_AIFACTORY_BRANCH=feature/example-change
# PR number for scenario 7 of the e2e smoke:
# TFACTORY_AIFACTORY_PR=42


# ─── Docker runner (Task 4) ────────────────────────────────────────────
# Container image used by the Executor's sandboxed pytest run.
# TFACTORY_DOCKER_IMAGE_PYTHON=tfactory-runner-python:latest
# Container CLI: docker (default) or podman.
# TFACTORY_CONTAINER_BIN=docker


# ─── e2e smoke state (test harness only) ───────────────────────────────
# Override per-run if you don't want successive runs to share state.
# TFACTORY_E2E_STATE_DIR=$HOME/.tfactory
