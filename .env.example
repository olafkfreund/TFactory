# =============================================================================
# TFactory — root .env.example
# =============================================================================
# Copy to `.env` next to docker-compose.yml and override values as needed.
#
# This file is for the LOCAL DEV docker-compose deployment AND as a
# reference index of TFactory env vars. Production deployments use
# the Helm chart / gitops (apps/tfactory/manifests) — see
# guides/deployment/runbook.md.
#
# FULL REFERENCE: docs/environment-reference.md documents every variable the
# backend reads (default, required?, purpose, source file). This file lists the
# operator-relevant ones with placeholder defaults.
#
# Legend:
#   [write]     = causes a real side effect (git commit, PR comment, webhook).
#   default ON  = active unless you set a falsy value (0/false/no/off).
#   default OFF = does nothing until you opt in (1/true/yes/on).
#
# Per-app envs live alongside their app:
#   - Web-server portal:  apps/web-server/.env.example
#   - Backend agents:     (no per-app .env.example yet; vars listed below)
# =============================================================================


# ─── docker-compose host port mapping ──────────────────────────────────
# Host port the web server is published to. Default 3102 matches APP_PORT.
# HOST_PORT=3102


# ─── docker-compose persistent data ────────────────────────────────────
# Bind-mounted at /home/nonroot/.tfactory inside the container. Holds the
# auto-generated API token, project metadata, audit log SQLite (until P1
# Postgres migration lands).
# TFACTORY_DATA_DIR=./data


# ─── Container runtime overrides (forwarded into the container) ────────
# Auto-generated on first run if unset.
# APP_API_TOKEN=

# Set via the UI OAuth flow instead (preferred). Primary Claude auth.
# CLAUDE_CODE_OAUTH_TOKEN=

# Extra CORS origins for the web-server (comma-separated or JSON list).
# APP_CORS_ORIGINS=https://my-host.example.com:3102,http://my-host.example.com:3100


# ─── Agent LLM provider keys (used by Planner / Gen-Functional /
#     Evaluator / Triager when they call out via the providers/factory) ─
# At least ONE provider must be configured for the pipeline to run.
# CLAUDE_CODE_OAUTH_TOKEN (above) is the preferred Claude path.
# ANTHROPIC_API_KEY is a fallback and is NEVER forwarded to verify Jobs
# (avoids silent API billing).
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=          # CCR/proxy token for enterprise setups
# ANTHROPIC_BASE_URL=            # custom Anthropic/SDK endpoint
# ANTHROPIC_MODEL=               # model override passed to the SDK
# ANTHROPIC_DEFAULT_HAIKU_MODEL= # maps the "haiku" shorthand
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_MAX_TOKENS=
# OPENAI_COMPATIBLE_REASONING_EFFORT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BASE_URL=
# AZURE_OPENAI_LLM_DEPLOYMENT=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_LLM_MODEL=gemini-2.0-flash
# OLLAMA_BASE_URL=
# OLLAMA_CLOUD_BASE_URL=
# OLLAMA_API_KEY=
# OLLAMA_LLM_MODEL=
# OLLAMA_EMBEDDING_MODEL=
# OLLAMA_EMBEDDING_DIM=0
# OPENROUTER_API_KEY=
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-3
# GITHUB_TOKEN=                  # GitHub Models, Copilot dispatch, GitLab ops
# GITHUB_MODELS_DEFAULT=openai/gpt-4.1
# QA_LLM_PROVIDER=               # force a provider for the QA/verify phase
# AUTO_BUILD_MODEL=              # model for the auto-build CLI path
# UTILITY_MODEL_ID=              # model for small utility LLM calls
# UTILITY_THINKING_BUDGET=


# ─── SDK runtime knobs (passed through to the Claude agent subprocess) ─
# NO_PROXY=
# DISABLE_TELEMETRY=
# DISABLE_COST_WARNINGS=
# API_TIMEOUT_MS=
# AIFACTORY_BASH_SANDBOX=true    # default ON; set falsy on k3d/Kind (no bwrap)


# ─── TFactory workspace + paths ────────────────────────────────────────
# Workspace root that the portal endpoints + the agents read/write from.
# Default ~/.tfactory.
# TFACTORY_WORKSPACE_ROOT=~/.tfactory
# TFACTORY_DATA_ROOT=            # data root for Nix Job co-mount derivation
# TFACTORY_SPEC_DIR=            # spec dir the MCP server operates on
# TFACTORY_PROJECT_DIR=        # project dir for MCP (falls back to CLAUDE_PROJECT_DIR)
# TFACTORY_API_URL=            # TFactory HTTP API base URL (agent tools)
# TFACTORY_SELF_API_URL=http://localhost:3103   # used by the handback sender
# TFACTORY_API_TOKEN_FILE=     # path to the TFactory API token file
# TFACTORY_MCP_KEY=            # API key the agent client sends to the API/MCP
# TFACTORY_PORTAL_PORT=3103    # portal port for task-detail links
# TFACTORY_CLOUD_ASSESSMENT_ROOT=
# TFACTORY_VISUAL_INSPECTION_ROOT=


# ─── Pipeline auto-fire gates ──────────────────────────────────────────
# Each defaults to "1" (auto-advance ON). Test fixtures set to "0";
# operators may pin some OFF to inspect each stage.
# TFACTORY_AUTO_PLAN=1       # Planner auto-fires from task_create_and_run
# TFACTORY_AUTO_GENERATE=1   # Gen-Functional auto-fires from Planner
# TFACTORY_AUTO_EVALUATE=1   # Evaluator auto-fires from Gen-Functional
# TFACTORY_AUTO_TRIAGE=1     # Triager auto-fires from Evaluator
# TFACTORY_REVIEW_LANE=0     # default OFF; additive adversarial review lane


# ─── Triager side-effect modes (default DRY-RUN — opt in to real-run) ──
# Per CLAUDE.md: "NO automatic pushes to GitHub" — keep these off unless
# the operator has confirmed git_writer/pr_comment are safe.
# TFACTORY_TRIAGER_GIT_WRITE=0     # [write] commit accepted tests to branch
# TFACTORY_TRIAGER_PR_COMMENT=0    # [write] post triage report via gh pr comment
# TFACTORY_PR_STATUS=0             # [write] publish quality-gate commit status
# TFACTORY_TRIAGER_GIT_SIGN=0      # GPG-sign the git-writer commits
# TFACTORY_TRIAGER_HARVEST=1       # [write] default ON; promote accepts to
#                                  #   <project>/.tfactory/templates/ (set 0 to skip)
# TFACTORY_TRIAGER_HARVEST_GLOBAL=0  # [write] also write to ~/.tfactory/templates/


# ─── Completion + stage events (all default OFF; best-effort) ──────────
# TFACTORY_COMPLETION_WEBHOOK=              # [write] URL POSTed on completion
# TFACTORY_COMPLETION_WEBHOOK_TIMEOUT=5
# TFACTORY_COMPLETION_SENTINEL=0            # write findings/COMPLETED.json
# TFACTORY_COMPLETION_OUTBOX=0              # durable retrying outbox
# TFACTORY_COMPLETION_OUTBOX_BACKOFF_BASE=5
# TFACTORY_COMPLETION_OUTBOX_BACKOFF_CAP=3600
# TFACTORY_COMPLETION_OUTBOX_MAX_ATTEMPTS=20
# TFACTORY_STAGE_EVENT_SENTINEL=0           # per-stage sentinel files
# TFACTORY_STAGE_EVENT_WEBHOOK=             # [write] URL POSTed per stage
# TFACTORY_STAGE_EVENT_WEBHOOK_TIMEOUT=5
# TFACTORY_EVENT_SOURCE=                    # override CloudEvents source field


# ─── Handback loop (re-verify failing builds via AIFactory) ────────────
# TFACTORY_HANDBACK_PREPARE=1   # default ON; prepare bundle on failure
# TFACTORY_HANDBACK_SEND=0      # [write] default OFF; actually send to AIFactory
# TFACTORY_HANDBACK_MAX_CYCLES=2


# ─── VAL-3 disposable target (real deploy target for tests) ────────────
# TFACTORY_VAL3_LOCAL_VM=0
# TFACTORY_VAL3_K8S_JOB=0
# TFACTORY_VAL3_CLOUD=          # value names the cloud/target profile
# TFACTORY_VAL3_TARGET_IS_PROD=0
# (TFACTORY_TARGET_URL is injected by TFactory into the runner — do not set.)


# ─── Nix runner / verify backend ───────────────────────────────────────
# TFACTORY_VERIFY_BACKEND=      # nixjob | docker | host (empty = auto)
# TFACTORY_RUNNER_MODE=         # host | docker (empty = auto)
# TFACTORY_NIX_RUNNER_IMAGE=    # required to enable the per-task Nix Job lane
# TFACTORY_NIX_IN_IMAGE=0       # Nix store baked into image (skip store PVC)
# TFACTORY_NIX_STORE_PVC=       # PVC for shared Nix store
# TFACTORY_WORKSPACES_PVC=      # PVC for shared workspaces / data root
# TFACTORY_SANDBOX_NAMESPACE=factory
# TFACTORY_VERIFY_EXEC=inpod    # inpod | kubejob
# TFACTORY_EQUIVALENCE_LANE=0   # source-vs-port equivalence lane
# TFACTORY_EQUIVALENCE_BACKEND=docker
# TFACTORY_EQUIVALENCE_IMAGE=   # default depends on backend
# TFACTORY_VERDICT_VOTES=3      # best-of-N evaluation passes
# TFACTORY_CI_PARITY=1          # default ON; CI-parity defaults in docker runner
# TFACTORY_CONTAINER_BIN=docker # docker (default) or podman


# ─── Verify-Job credential injection (TFACTORY_VERIFY_EXEC=kubejob) ─────
# ANTHROPIC_API_KEY is never forwarded to verify Jobs.
# TFACTORY_VERIFY_IMAGE=                    # explicit image for the verify Job
# TFACTORY_IMAGE=                           # running control-plane image (reused)
# APP_BACKEND_PATH=/home/projects/MagesticAI/apps/backend
# TFACTORY_VERIFY_OAUTH_SECRET_NAME=        # Secret with the Claude OAuth token
# TFACTORY_VERIFY_OAUTH_SECRET_KEY=oauth-token
# TFACTORY_VERIFY_PROVIDER_SECRET_NAME=     # Secret for non-Claude provider keys
# TFACTORY_VERIFY_CLI_CREDS_SECRET=         # Secret with CLI credentials
# DATABASE_URL=                             # forwarded to the verify Job when needed


# ─── Infra / gates / liveness ──────────────────────────────────────────
# TFACTORY_STALL_DEADLINE_SECONDS=900   # idle budget before a stage is stalled
# TFACTORY_DEP_AGE_CHECK=1              # default ON; dependency freshness gate
# TFACTORY_EGRESS_ENABLED=0            # allow network egress (secrets guard)
# TFACTORY_BATCH_MIN_JOBS=2            # insight-extraction batch minimum
# TFACTORY_BATCH_TIMEOUT=120
# TFACTORY_BATCH_DISABLE=0
# KUBECONFIG=                          # k8s evaluator target (else in-cluster)
# DEFAULT_BRANCH=                      # default branch for worktree git ops


# ─── Secrets backends ──────────────────────────────────────────────────
# VAULT_ADDR=                  # required for the Vault backend
# VAULT_TOKEN=
# AWS_REGION=                  # required for the AWS Secrets Manager backend
# AWS_DEFAULT_REGION=


# ─── Backstage integration ─────────────────────────────────────────────
# BACKSTAGE_BASE_URL=                        # also enables the docs target
# TFACTORY_BACKSTAGE_TECHINSIGHTS_URL=
# TFACTORY_BACKSTAGE_TOKEN=
# TFACTORY_BACKSTAGE_COMPONENT=


# ─── Docs emission ─────────────────────────────────────────────────────
# TFACTORY_DOCS_DIR=            # override local output dir for emitted docs
# TFACTORY_DOCS_BACKSTAGE=0     # enable Backstage TechDocs target
# TFACTORY_DOCS_CONFLUENCE=0    # enable Confluence target
# CONFLUENCE_BASE_URL=          # required for the Confluence target
# CONFLUENCE_API_TOKEN=
# CONFLUENCE_SPACE=


# ─── Knowledge graph (Graphiti / Graphiti-MCP) ─────────────────────────
# GRAPHITI_ENABLED=0
# GRAPHITI_LLM_PROVIDER=openai
# GRAPHITI_EMBEDDER_PROVIDER=
# GRAPHITI_DATABASE=
# GRAPHITI_DB_PATH=
# GRAPHITI_MCP_URL=http://localhost:3102/mcp/
# INSIGHT_EXTRACTION_ENABLED=true
# INSIGHT_EXTRACTOR_MODEL=


# ─── Misc / diagnostics ────────────────────────────────────────────────
# DEBUG=0
# DEBUG_LEVEL=1
# DEBUG_LOG_FILE=
# QUICK_MODE=false             # shorter/faster prompts
# USE_CLAUDE_MD=false          # load repo CLAUDE.md into agent context
# ENABLE_FANCY_UI=true         # default ON; rich terminal UI
# FACTORY_SERVICE_NAME=the Factory


# ─── AIFactory project location (used by the snapshotter + e2e smoke) ──
# Local path to the AIFactory checkout TFactory operates on.
# TFACTORY_AIFACTORY_ROOT=/home/user/Source/GitHub/MyApp
# TFACTORY_AIFACTORY_API_URL=
# Feature branch carrying the change to test:
# TFACTORY_AIFACTORY_BRANCH=feature/example-change
# PR number for scenario 7 of the e2e smoke:
# TFACTORY_AIFACTORY_PR=42


# ─── Docker runner (Task 4) ────────────────────────────────────────────
# Container image used by the Executor's sandboxed pytest run.
# TFACTORY_DOCKER_IMAGE_PYTHON=tfactory-runner-python:latest


# ─── e2e smoke state (test harness only) ───────────────────────────────
# Override per-run if you don't want successive runs to share state.
# TFACTORY_E2E_STATE_DIR=$HOME/.tfactory
