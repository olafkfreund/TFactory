# MagesticAI Web Server Configuration
# Copy this file to .env and modify as needed

# Server settings
APP_HOST=0.0.0.0
APP_PORT=3103
APP_DEBUG=true

# Authentication
# If not set, a token will be auto-generated on first run
# APP_API_TOKEN=your-secure-token-here

# CORS origins — accepts a comma-separated list OR a JSON array.
# Examples:
#   APP_CORS_ORIGINS=https://app.example.com,https://api.example.com
#   APP_CORS_ORIGINS=["http://localhost:3100","http://localhost:3000"]
# Defaults already cover http(s)://localhost:{3000,3100,3103}.
# APP_CORS_ORIGINS=

# Paths (auto-detected if not set)
# APP_BACKEND_PATH=/path/to/apps/backend
# APP_PROJECTS_DATA_DIR=/path/to/data/directory

# Terminal settings
APP_DEFAULT_SHELL=/bin/bash
APP_MAX_TERMINALS=20

# Task execution
APP_MAX_CONCURRENT_TASKS=5

# ─── TFactory portal (Task 9 / #10) ────────────────────────────────────
# Workspace root the /api/tfactory/tasks endpoints scan for spec dirs.
# Default ~/.tfactory. Set to override (tests use this with a tmp dir).
# TFACTORY_WORKSPACE_ROOT=~/.tfactory

# ─── TFactory pipeline auto-advance (the four agent stages) ────────────
# Each defaults to "1" (auto-chain ON). Test fixtures set to "0".
# Production deployments may want some OFF if the operator wants to
# inspect each stage's output before the next fires.
# TFACTORY_AUTO_PLAN=1       # Planner auto-fires from task_create_and_run
# TFACTORY_AUTO_GENERATE=1   # Gen-Functional auto-fires from Planner
# TFACTORY_AUTO_EVALUATE=1   # Evaluator auto-fires from Gen-Functional
# TFACTORY_AUTO_TRIAGE=1     # Triager auto-fires from Evaluator

# ─── Triager side-effect modes (default DRY-RUN — opt in to real-run) ──
# Per CLAUDE.md: "NO automatic pushes to GitHub" — keep these off
# unless the operator has confirmed git_writer/pr_comment are safe.
# TFACTORY_TRIAGER_GIT_WRITE=0   # commit accepted tests to feature branch
# TFACTORY_TRIAGER_PR_COMMENT=0  # post triage report via gh pr comment
