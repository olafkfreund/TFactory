# MagesticAI Web Server Configuration
# Copy this file to .env and modify as needed

# Server settings
APP_HOST=0.0.0.0
APP_PORT=3102
APP_DEBUG=true

# Authentication
# If not set, a token will be auto-generated on first run
# APP_API_TOKEN=your-secure-token-here

# CORS origins — accepts a comma-separated list OR a JSON array.
# Examples:
#   APP_CORS_ORIGINS=https://app.example.com,https://api.example.com
#   APP_CORS_ORIGINS=["http://localhost:3100","http://localhost:3000"]
# Defaults already cover http(s)://localhost:{3000,3100,3102}.
# APP_CORS_ORIGINS=

# Paths (auto-detected if not set)
# APP_BACKEND_PATH=/path/to/apps/backend
# APP_PROJECTS_DATA_DIR=/path/to/data/directory

# Terminal settings
APP_DEFAULT_SHELL=/bin/bash
APP_MAX_TERMINALS=20

# Task execution
APP_MAX_CONCURRENT_TASKS=5
