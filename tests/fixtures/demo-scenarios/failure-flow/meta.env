# Scenario metadata for /demo and scripts/demo/seed-scenario.sh.
# failure-flow is a narrative lens over a base scenario (default greeting-generator):
# same seed, but the demo opts the Triager into a LOCAL git write so the merge of
# the accepted tests is real. Never enables PR comments.
SCENARIO_ID=failure-flow
BASE_SCENARIO=greeting-generator
EXPECT_FAILURE=1
TFACTORY_TRIAGER_GIT_WRITE=1
