---
description: Error state — stub the API to fail, assert the UI shows an error message (not a crash)
requires_target: true
requires_auth: false
vars:
  - target_base_url
  - test_name
  - page_path
  - api_method
  - api_url_glob
  - error_status
  - error_selector
  - expected_error_text
---
describe('${test_name}', () => {
  it('shows an error state when the API fails', () => {
    cy.intercept('${api_method}', '${api_url_glob}', { statusCode: ${error_status}, body: {} }).as('apiCall');

    cy.visit('${target_base_url}${page_path}');
    cy.wait('@apiCall');

    cy.get('${error_selector}')
      .should('be.visible')
      .and('contain.text', '${expected_error_text}');
  });
});
