---
description: Form validation — submit with a missing field, assert the inline error appears
requires_target: true
requires_auth: false
vars:
  - target_base_url
  - test_name
  - form_path
  - submit_selector
  - error_selector
  - expected_error_text
---
describe('${test_name}', () => {
  it('shows a validation error when a required field is empty', () => {
    cy.visit('${target_base_url}${form_path}');

    // Submit without filling the form.
    cy.get('${submit_selector}').click();

    // The error element should become visible with the expected message.
    cy.get('${error_selector}')
      .should('be.visible')
      .and('contain.text', '${expected_error_text}');
  });
});
