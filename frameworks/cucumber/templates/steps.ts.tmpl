---
description: Cucumber step definitions — drive the SUT via the World; step text MUST match the .feature
requires_target: true
requires_auth: false
vars:
  - given_step
  - when_step
  - then_step
  - target_selector
  - expected_text
---
import { Given, When, Then } from '@cucumber/cucumber';
import { expect } from '@playwright/test';
import { CustomWorld } from './support/world';

Given('${given_step}', async function (this: CustomWorld) {
  await this.page.goto(this.baseUrl);
});

When('${when_step}', async function (this: CustomWorld) {
  await this.page.locator('${target_selector}').click();
});

Then('${then_step}', async function (this: CustomWorld) {
  await expect(this.page.getByText('${expected_text}')).toBeVisible();
});
