---
description: Load balancer — assert the health endpoint is up and repeated requests all succeed (round-robin sanity) (api lane)
requires_target: true
requires_auth: false
vars:
  - health_path
  - sample_requests
---
import os

import httpx

BASE_URL = os.environ["TFACTORY_TARGET_URL"].rstrip("/")


def test_load_balancer_health_and_distribution() -> None:
    health = httpx.get(f"{BASE_URL}${health_path}", timeout=15)
    assert health.status_code == 200, f"LB health {health.status_code}: {health.text}"

    # Repeated requests should all succeed regardless of which backend serves them.
    statuses = []
    for _ in range(${sample_requests}):
        r = httpx.get(f"{BASE_URL}${health_path}", timeout=15)
        statuses.append(r.status_code)
    assert all(s == 200 for s in statuses), f"some requests failed: {statuses}"
