---
description: Salesforce REST — run a SOQL query and assert it returns records with a field (api lane; needs target URL + OAuth bearer token)
requires_target: true
requires_auth: true
vars:
  - soql
  - expected_field
  - min_records
---
import os

import httpx

# api lane injects TFACTORY_TARGET_URL (your Salesforce instance, e.g.
# https://acme.my.salesforce.com) + TEST_PASSWORD (an OAuth bearer token).
BASE_URL = os.environ["TFACTORY_TARGET_URL"].rstrip("/")
TOKEN = os.environ.get("TEST_PASSWORD", "")


def test_salesforce_soql_returns_records() -> None:
    resp = httpx.get(
        f"{BASE_URL}/services/data/v60.0/query",
        params={"q": "${soql}"},
        headers={"Authorization": f"Bearer {TOKEN}", "Accept": "application/json"},
        timeout=30,
    )
    assert resp.status_code == 200, f"Salesforce API {resp.status_code}: {resp.text}"
    body = resp.json()
    assert body.get("totalSize", 0) >= ${min_records}
    assert body.get("records"), "SOQL query returned no records"
    assert "${expected_field}" in body["records"][0]
