---
description: Mulesoft / generic REST API — call an endpoint and assert the status + a JSON key in the response (api lane; auth optional)
requires_target: true
requires_auth: false
vars:
  - path
  - expected_status
  - expected_json_key
---
import os

import httpx

BASE_URL = os.environ["TFACTORY_TARGET_URL"].rstrip("/")
TOKEN = os.environ.get("TEST_PASSWORD", "")
HEADERS = {"Accept": "application/json"}
if TOKEN:
    HEADERS["Authorization"] = f"Bearer {TOKEN}"


def test_mulesoft_endpoint_contract() -> None:
    resp = httpx.get(f"{BASE_URL}${path}", headers=HEADERS, timeout=30)
    assert resp.status_code == ${expected_status}, resp.text
    body = resp.json()
    assert "${expected_json_key}" in body
