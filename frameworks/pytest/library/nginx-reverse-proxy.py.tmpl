---
description: Nginx reverse proxy — assert a path is served with the expected status and an nginx/upstream header (api lane)
requires_target: true
requires_auth: false
vars:
  - path
  - expected_status
  - upstream_header
---
import os

import httpx

BASE_URL = os.environ["TFACTORY_TARGET_URL"].rstrip("/")


def test_nginx_proxies_path() -> None:
    resp = httpx.get(f"{BASE_URL}${path}", timeout=15)
    assert resp.status_code == ${expected_status}, resp.text
    # Nginx commonly sets a Server header; an upstream may add its own marker.
    server = resp.headers.get("server", "").lower()
    assert "nginx" in server or "${upstream_header}" in resp.headers
