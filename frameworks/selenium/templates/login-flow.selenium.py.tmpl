---
description: Selenium login flow — fill injected creds, submit, wait for the success URL (no sleeps)
requires_target: true
requires_auth: true
vars:
  - test_name
  - login_path
  - username_selector
  - password_selector
  - submit_selector
  - success_url_fragment
  - username_env
  - secret_env
---
import os

from selenium.webdriver.common.by import By
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.support.ui import WebDriverWait


def test_${test_name}(driver, base_url):
    driver.get(base_url + "${login_path}")
    wait = WebDriverWait(driver, 10)
    # Credentials come from the injected env vars, never hard-coded.
    wait.until(EC.visibility_of_element_located((By.CSS_SELECTOR, "${username_selector}"))).send_keys(
        os.environ.get("${username_env}", "")
    )
    driver.find_element(By.CSS_SELECTOR, "${password_selector}").send_keys(
        os.environ.get("${secret_env}", "")
    )
    driver.find_element(By.CSS_SELECTOR, "${submit_selector}").click()
    wait.until(EC.url_contains("${success_url_fragment}"))
    assert "${success_url_fragment}" in driver.current_url
