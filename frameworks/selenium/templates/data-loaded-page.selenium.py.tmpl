---
description: Selenium data-loaded assertion — wait for async content then assert it rendered
requires_target: true
requires_auth: false
vars:
  - test_name
  - page_path
  - content_selector
  - expected_text
---
from selenium.webdriver.common.by import By
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.support.ui import WebDriverWait


def test_${test_name}(driver, base_url):
    driver.get(base_url + "${page_path}")
    # Wait for the async-loaded content — never assert before it appears.
    el = WebDriverWait(driver, 10).until(
        EC.visibility_of_element_located((By.CSS_SELECTOR, "${content_selector}"))
    )
    assert "${expected_text}" in el.text
