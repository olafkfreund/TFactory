---
description: Form submit validation — fill invalid input, submit, assert inline error message
requires_target: true
requires_auth: false
vars:
  - target_base_url
  - test_name
  - form_url
  - field_selector
  - expected_error_text
---
import { test, expect } from '@playwright/test';

test('${test_name}', async ({ page }) => {
  await page.goto('${target_base_url}${form_url}');

  // Clear the field to trigger a required-field validation error
  const field = page.locator('${field_selector}');
  await field.fill('');
  await field.blur();

  // Submit the form
  await page.getByRole('button', { name: /submit/i }).click();

  // Assert the validation error is visible
  await expect(page.getByText('${expected_error_text}')).toBeVisible();
});
