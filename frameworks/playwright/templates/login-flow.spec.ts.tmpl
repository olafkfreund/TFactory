---
description: Login flow — fill credentials, submit, assert redirect to success URL
requires_target: true
requires_auth: false
vars:
  - target_base_url
  - test_name
  - username_selector
  - password_selector
  - submit_selector
  - success_url_pattern
---
import { test, expect } from '@playwright/test';

test('${test_name}', async ({ page }) => {
  await page.goto('${target_base_url}/login');

  // Fill login form
  await page.locator('${username_selector}').fill('test-user@example.com');
  await page.locator('${password_selector}').fill('test-password-123');

  // Submit and wait for navigation
  await Promise.all([
    page.waitForURL('**/${success_url_pattern}**'),
    page.locator('${submit_selector}').click(),
  ]);

  // Assert the redirect completed to the expected URL pattern
  expect(page.url()).toContain('${success_url_pattern}');
});
