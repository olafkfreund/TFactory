# TFactory development environment — auto-loaded by direnv.
#
# Loads the flake's devShells.default (devenv.nix). On NixOS systems with
# nix-direnv installed, this gives you instant shell-entry every time
# you `cd` into the repo.
#
# First-time setup:
#   nix profile install nixpkgs#nix-direnv
#   direnv allow
#
# Without direnv, run `nix develop` explicitly.

if ! has nix_direnv_version || ! nix_direnv_version 3.0.5; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.5/direnvrc" \
             "sha256-RuwIS+QKFj/T9M2TFXScjBsLR6V3A17YVoEW/Q6AZ1w="
fi

use flake

# Optional: load .env if present for local overrides (TFACTORY_API_KEY, etc.)
dotenv_if_exists .env
