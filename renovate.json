{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "schedule": ["before 9am on monday"],
  "timezone": "UTC",
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,

  "pinDigests": true,
  "dockerfile": {
    "fileMatch": ["(^|/)Dockerfile([^/]*)?$"]
  },

  "packageRules": [
    {
      "description": "Base image digest updates: deliberate, never auto-merged. Bumping a base image without re-running the docker-acceptance suite is how regressions ship.",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["digest"],
      "labels": ["dependencies", "docker", "base-image"],
      "commitMessageTopic": "{{depName}} digest",
      "automerge": false
    },
    {
      "description": "GitHub Actions used by the CI workflows — pin by SHA per supply-chain best practice.",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "labels": ["dependencies", "ci"]
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  }
}
