{
  "name": "tfactory",
  "version": "0.9.2",
  "description": "TFactory - Web-based AI task management and agent orchestration platform powered by Claude AI",
  "license": "MIT OR GPL-3.0-only",
  "author": "DataSeek Team",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "install:backend": "node scripts/install-backend.js",
    "install:frontend": "cd apps/frontend-web && npm install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "dev": "cd apps/frontend-web && npm run dev",
    "build": "cd apps/frontend-web && npm run build",
    "lint": "cd apps/frontend-web && npm run lint",
    "test": "cd apps/frontend-web && npm test",
    "test:backend": "node scripts/test-backend.js",
    "docs:install": "cd docs && npm install",
    "docs:dev": "cd docs && npm start",
    "docs:build": "cd docs && npm run build",
    "demo": "./scripts/demo.sh",
    "screenshots": "npm -w apps/frontend-web run capture-screenshots"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/olafkfreund/TFactory.git"
  },
  "homepage": "https://github.com/olafkfreund/TFactory",
  "bugs": {
    "url": "https://github.com/olafkfreund/TFactory/issues"
  },
  "keywords": [
    "ai",
    "tfactory",
    "task-management",
    "agent-orchestration",
    "web-ui",
    "fastapi",
    "react",
    "autonomous-agents"
  ],
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "jsdom": "^27.4.0",
    "playwright": "^1.60.0",
    "typescript": "^5.0.0"
  }
}
